{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "mayday-extension": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "",
            "sourceRoot": "src",
            "prefix": "ext",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "outputPath": "dist/extension",
                        "index": "src/index.html",
                        "browser": "src/main.ts",
                        "tsConfig": "tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "src/assets"
                            }
                        ],
                        "styles": ["src/styles.scss"],
                        "scripts": [],
                        "allowedCommonJsDependencies": ["pvtsutils", "webextension-polyfill"]
                    },
                    "configurations": {
                        "production": {
                            "aot": true,
                            "optimization": {
                                "scripts": true,
                                "styles": {
                                    "minify": true,
                                    "inlineCritical": false
                                },
                                "fonts": false
                            },
                            "sourceMap": false,
                            "outputHashing": "none",
                            "extractLicenses": false,
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "600kb",
                                    "maximumError": "1mb"
                                }
                            ]
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true,
                            "outputHashing": "none"
                        }
                    },
                    "defaultConfiguration": "production"
                }
            }
        }
    },
    "cli": {
        "analytics": false
    }
}
