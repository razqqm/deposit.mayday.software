{
    "name": "mayday-extension",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "ng": "ng",
        "build": "ng build --configuration production && node scripts/build.mjs",
        "build:firefox": "ng build --configuration production && node scripts/build.mjs --firefox",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "test:ci": "ng test --no-watch --code-coverage",
        "package:chrome": "npm run build && cd dist/extension && zip -r ../mayday-ext-chrome.zip .",
        "package:firefox": "npm run build:firefox && cd dist/extension && zip -r ../mayday-ext-firefox.zip ."
    },
    "dependencies": {
        "@angular/animations": "^21",
        "@angular/common": "^21",
        "@angular/compiler": "^21",
        "@angular/core": "^21",
        "@angular/forms": "^21",
        "@angular/platform-browser": "^21",
        "@ngx-translate/core": "^17.0.0",
        "asn1js": "^3.0.7",
        "openpgp": "^6.3.0",
        "pkijs": "^3.4.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.8.1",
        "webextension-polyfill": "^0.12.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^21",
        "@angular/cli": "^21",
        "@angular/compiler-cli": "^21",
        "@types/jasmine": "~5.1.0",
        "@types/webextension-polyfill": "^0.12.1",
        "esbuild": "^0.25.0",
        "jasmine-core": "~5.4.0",
        "karma": "~6.4.0",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "typescript": "~5.9.3"
    }
}
